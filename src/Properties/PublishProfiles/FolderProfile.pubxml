<?xml version="1.0" encoding="utf-8"?>
<!-- https://go.microsoft.com/fwlink/?LinkID=208121. -->
<Project>
  <PropertyGroup>
    <!-- Build configuration: optimized, no debug symbols -->
    <Configuration>Release</Configuration>
    <!-- Platform: Any CPU in project settings, but overridden by RuntimeIdentifier below -->
    <Platform>x64</Platform>
    <!-- Output location: relative to project folder (src/bin/Publish/) -->
    <!-- Alternative: absolute path like E:\SOFTWARE-Win11\Smart_Stay_Awake\dist -->
    <PublishDir>bin\Publish\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <!-- Target framework: .NET 10, Windows 10 version 2004+ (19041) -->
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <!-- Runtime: Force 64-bit (x64) - won't run on 32-bit Windows -->
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
	  
    <!-- Self-contained: Bundle .NET 10 runtime (~60MB), no installation needed -->
    <!-- Single file: All DLLs bundled into one .exe -->
    <!-- ReadyToRun: Pre-compile for faster startup (larger file) -->
    <!-- Trimming disabled: Safe for P/Invoke and CsWin32 reflection -->
<!-- Commented out since this is for single-exe non-AOT
	<SelfContained>true</SelfContained> 
	<PublishTrimmed>false</PublishTrimmed>
-->
<!-- this is ONLY for AOT single-exe, which is smaller than non-AOT single-exe -->
	<PublishAot>true</PublishAot>
	<PublishTrimmed>true</PublishTrimmed>
	<_AllowWindowsFormsWithTrim>true</_AllowWindowsFormsWithTrim>
	<SuppressTrimAnalysisWarnings>false</SuppressTrimAnalysisWarnings>
    <_SuppressWinFormsTrimError>true</_SuppressWinFormsTrimError>
	<StripSymbols>true</StripSymbols>
	<TrimMode>link</TrimMode>
  </PropertyGroup>
</Project>